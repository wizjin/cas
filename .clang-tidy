---
Checks: >-
  -*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  readability-*,
  -readability-braces-around-statements,
  bugprone-*

CheckOptions:
  - key: readability-identifier-naming.TypedefSuffix
    value: _t
WarningsAsErrors: '*'
HeaderFilterRegex: '^(src|include)/.*'
SystemHeaders: false
FormatStyle: none
